diff --git a/src/cartservice/src/Program.cs b/src/cartservice/src/Program.cs
index 3d18d8f..c6cc7df 100644
--- a/src/cartservice/src/Program.cs
+++ b/src/cartservice/src/Program.cs
@@ -1,5 +1,10 @@
 using System;
+using OpenTelemetry.Metrics;
+using OpenTelemetry.Resources;
+using OpenTelemetry.Trace;
 using Microsoft.AspNetCore.Builder;
 using Microsoft.Extensions.DependencyInjection;
 using Microsoft.Extensions.Hosting;
@@ -10,6 +15,29 @@ var builder = WebApplication.CreateBuilder(args);
 
 builder.Services.AddGrpc();
 builder.Services.AddSingleton<CartStore>();
+
+builder.Services.AddOpenTelemetry()
+    .ConfigureResource(resource => resource
+        .AddService(serviceName: "cartservice", serviceVersion: "1.0.0")
+        .AddAttributes(new[]
+        {
+            new KeyValuePair<string, object>("deployment.environment", "assessment")
+        }))
+    .WithTracing(tracing => tracing
+        .AddAspNetCoreInstrumentation()
+        .AddGrpcClientInstrumentation()
+        .AddHttpClientInstrumentation()
+        .AddSource("cartservice")
+        .AddOtlpExporter(options =>
+        {
+            options.Endpoint = new Uri(Environment.GetEnvironmentVariable("OTEL_EXPORTER_OTLP_ENDPOINT") ?? "http://otel-agent:4318");
+        }))
+    .WithMetrics(metrics => metrics
+        .AddAspNetCoreInstrumentation()
+        .AddRuntimeInstrumentation()
+        .AddProcessInstrumentation()
+        .AddMeter("cartservice")
+        .AddOtlpExporter(options =>
+        {
+            options.Endpoint = new Uri(Environment.GetEnvironmentVariable("OTEL_EXPORTER_OTLP_ENDPOINT") ?? "http://otel-agent:4318");
+        }));
 
 var app = builder.Build();
 app.MapGrpcService<CartService>();
 app.MapGet("/", () => "CartService is running");
 app.Run();

diff --git a/src/cartservice/src/Telemetry.cs b/src/cartservice/src/Telemetry.cs
new file mode 100644
