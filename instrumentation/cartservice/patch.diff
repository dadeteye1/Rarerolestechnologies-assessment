--- /dev/null
+++ b/src/cartservice/src/Telemetry.cs
@@ -0,0 +1,12 @@
+using System.Diagnostics;
+using System.Diagnostics.Metrics;
+
+internal static class Telemetry
+{
+    public static readonly ActivitySource ActivitySource = new("cartservice");
+    public static readonly Meter Meter = new("cartservice");
+    public static readonly Counter<long> CartOperations =
+        Meter.CreateCounter<long>("cart.operations");
+}

diff --git a/src/cartservice/src/CartStore.cs b/src/cartservice/src/CartStore.cs
index 4b2df1f..a289ef5 100644
--- a/src/cartservice/src/CartStore.cs
+++ b/src/cartservice/src/CartStore.cs
@@ -37,6 +37,12 @@ public class CartStore
     public async Task AddItemAsync(string userId, string productId, int quantity)
     {
+        using var activity = Telemetry.ActivitySource.StartActivity("cart.add_item");
+        activity?.SetTag("user.id", userId);
+        activity?.SetTag("product.id", productId);
+        activity?.SetTag("product.count", quantity);
+        Telemetry.CartOperations.Add(1, new KeyValuePair<string, object>("operation", "add"));
+
         var cart = await GetCartAsync(userId);
         cart.Items.Add(new CartItem { ProductId = productId, Quantity = quantity });
         await SaveCartAsync(userId, cart);
     }
@@ -44,6 +50,11 @@ public class CartStore
     public async Task EmptyCartAsync(string userId)
     {
+        using var activity = Telemetry.ActivitySource.StartActivity("cart.empty");
+        activity?.SetTag("user.id", userId);
+        Telemetry.CartOperations.Add(1, new KeyValuePair<string, object>("operation", "empty"));
+
         await _redis.KeyDeleteAsync(GetCartKey(userId));
     }
 }
